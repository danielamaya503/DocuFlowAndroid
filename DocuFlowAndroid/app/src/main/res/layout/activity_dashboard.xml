<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- ══════════════════════════════════════
         APP BAR + BUSCADOR (juntos en AppBar)
    ══════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/barra_superior"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A237E"
        app:elevation="0dp">

        <!-- Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/boton_menu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Menú"
                android:src="@drawable/ic_menu"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/texto_titulo_toolbar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="DocuFlow"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/boton_notificaciones"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Notificaciones"
                android:src="@drawable/ic_notifications"
                app:tint="@android:color/white" />

            <!-- Avatar círculo con iniciales -->
            <TextView
                android:id="@+id/texto_avatar_usuario"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_avatar"
                android:gravity="center"
                android:text="DA"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Buscador debajo del toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="24dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/contenedor_buscador"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="@android:color/white"
                app:boxCornerRadiusBottomEnd="99dp"
                app:boxCornerRadiusBottomStart="99dp"
                app:boxCornerRadiusTopEnd="99dp"
                app:boxCornerRadiusTopStart="99dp"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:startIconDrawable="@drawable/ic_search"
                app:startIconTint="#757575">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/campo_buscador"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Buscar documentos..."
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══════════════════════════════════════
         CONTENIDO PRINCIPAL (scroll)
    ══════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── CHIPS FILTRO ── -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_todos"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:checked="true"
                        android:text="Todos"
                        android:textColor="@android:color/white"
                        app:chipBackgroundColor="#1A237E"
                        app:chipStrokeColor="#1A237E"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_borrador"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="Borrador"
                        android:textColor="#212121"
                        app:chipBackgroundColor="@android:color/white"
                        app:chipStrokeColor="#CBD5E1"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_en_revision"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="En Revisión"
                        android:textColor="#212121"
                        app:chipBackgroundColor="@android:color/white"
                        app:chipStrokeColor="#CBD5E1"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_aprobado"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="Aprobado"
                        android:textColor="#212121"
                        app:chipBackgroundColor="@android:color/white"
                        app:chipStrokeColor="#CBD5E1"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_rechazado"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rechazado"
                        android:textColor="#212121"
                        app:chipBackgroundColor="@android:color/white"
                        app:chipStrokeColor="#CBD5E1"
                        app:chipStrokeWidth="1dp" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- ── HEADER DOCUMENTOS RECIENTES ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="12dp">

                <TextView
                    android:id="@+id/texto_titulo_seccion"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DOCUMENTOS RECIENTES"
                    android:textColor="#212121"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/enlace_ver_todo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VER TODO"
                    android:textColor="#1A237E"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- ══════════════════════════════════════
                 CARDS DE DOCUMENTOS
            ══════════════════════════════════════ -->

            <!-- Card 1: Aprobado -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tarjeta_documento_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:strokeColor="#F1F5F9"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <!-- Ícono documento rojo -->
                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_icono_rojo">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:contentDescription="Documento"
                            android:src="@drawable/ic_description"
                            app:tint="#DC2626" />
                    </FrameLayout>

                    <!-- Textos -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/texto_nombre_doc1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="Contrato de Servicios 2026"
                            android:textColor="#212121"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/texto_meta_doc1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Contratos • Modificado hace 2 horas"
                            android:textColor="#757575"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Badge estado -->
                    <TextView
                        android:id="@+id/badge_estado_doc1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_badge_aprobado"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="APROBADO"
                        android:textColor="#15803D"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 2: En Revisión -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tarjeta_documento_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:strokeColor="#F1F5F9"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_icono_azul">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:contentDescription="Artículo"
                            android:src="@drawable/ic_article"
                            app:tint="#2563EB" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/texto_nombre_doc2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="Manual de Operaciones V3"
                            android:textColor="#212121"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/texto_meta_doc2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Manuales • Modificado hace 5 horas"
                            android:textColor="#757575"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/badge_estado_doc2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_badge_revision"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="EN REVISIÓN"
                        android:textColor="#B45309"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 3: Borrador -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tarjeta_documento_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="80dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:strokeColor="#F1F5F9"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_icono_rojo">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:contentDescription="Documento"
                            android:src="@drawable/ic_description"
                            app:tint="#DC2626" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/texto_nombre_doc3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="Propuesta Comercial Q4"
                            android:textColor="#212121"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/texto_meta_doc3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Comercial • Modificado ayer"
                            android:textColor="#757575"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/badge_estado_doc3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_badge_borrador"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="BORRADOR"
                        android:textColor="#475569"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══════════════════════════════════════
         FAB (botón flotante)
    ══════════════════════════════════════ -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_nuevo_documento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="72dp"
        android:contentDescription="Nuevo documento"
        android:src="@drawable/ic_add"
        app:backgroundTint="#00897B"
        app:tint="@android:color/white" />

    <!-- ══════════════════════════════════════
         BOTTOM NAVIGATION
    ══════════════════════════════════════ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/nav_inferior"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@android:color/white"
        app:itemIconTint="@drawable/selector_nav_color"
        app:itemTextColor="@drawable/selector_nav_color"
        app:menu="@menu/menu_navegacion_principal" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
