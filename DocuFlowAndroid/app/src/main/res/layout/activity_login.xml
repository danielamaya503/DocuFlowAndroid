<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Login">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F5F5"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp">

            <!-- ══════════════════════════════════════
                 SECCIÓN LOGO
            ══════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/seccion_logo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="80dp"
                android:paddingBottom="40dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <!-- Contenedor ícono logo -->
                <FrameLayout
                    android:id="@+id/contenedor_icono_logo"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_icono_logo"/>

                <!-- Título principal -->
                <TextView
                    android:id="@+id/texto_titulo_app"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DocuFlow"
                    android:textColor="#1A227F"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <!-- Subtítulo -->
                <TextView
                    android:id="@+id/texto_subtitulo_app"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Gestión Documental"
                    android:textColor="#64748B"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- ══════════════════════════════════════
                 TARJETA FORMULARIO
            ══════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tarjeta_formulario"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/seccion_logo">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- ── CAMPO CORREO ── -->
                    <TextView
                        android:id="@+id/etiqueta_correo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Correo electrónico"
                        android:textColor="#334155"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/contenedor_campo_correo"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxCornerRadiusBottomEnd="8dp"
                        app:boxCornerRadiusBottomStart="8dp"
                        app:boxCornerRadiusTopEnd="8dp"
                        app:boxCornerRadiusTopStart="8dp"
                        app:boxStrokeColor="#CBD5E1"
                        app:startIconDrawable="@drawable/ic_mail"
                        app:startIconTint="#94A3B8">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/campo_correo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="ejemplo@empresa.com"
                            android:inputType="textEmailAddress"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Mensaje de error correo (visible para prueba visual) -->
                    <LinearLayout
                        android:id="@+id/contenedor_mensaje_error"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="visible">

                        <ImageView
                            android:id="@+id/icono_error"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:contentDescription="Error"
                            android:src="@drawable/ic_error"
                            app:tint="#D32F2F" />

                        <TextView
                            android:id="@+id/texto_error_credenciales"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="Credenciales incorrectas"
                            android:textColor="#D32F2F"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- ── CAMPO CONTRASEÑA ── -->
                    <TextView
                        android:id="@+id/etiqueta_contrasena"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="6dp"
                        android:text="Contraseña"
                        android:textColor="#334155"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/contenedor_campo_contrasena"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxCornerRadiusBottomEnd="8dp"
                        app:boxCornerRadiusBottomStart="8dp"
                        app:boxCornerRadiusTopEnd="8dp"
                        app:boxCornerRadiusTopStart="8dp"
                        app:boxStrokeColor="#CBD5E1"
                        app:endIconMode="password_toggle"
                        app:endIconTint="#94A3B8"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="#94A3B8">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/campo_contrasena"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="••••••••"
                            android:inputType="textPassword"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- ── BOTÓN INICIAR SESIÓN ── -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/boton_iniciar_sesion"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="24dp"
                        android:text="Iniciar Sesión"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:backgroundTint="#1A227F"
                        app:cornerRadius="8dp" />

                    <!-- ── LINK OLVIDÉ CONTRASEÑA ── -->
                    <TextView
                        android:id="@+id/enlace_olvide_contrasena"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="¿Olvidaste tu contraseña?"
                        android:textColor="#00897B"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════
                 VERSIÓN
            ══════════════════════════════════════ -->
            <TextView
                android:id="@+id/texto_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="V1.0.0"
                android:textAllCaps="true"
                android:textColor="#94A3B8"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tarjeta_formulario" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>